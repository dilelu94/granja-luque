# Puerto en el que correrá el servidor backend
PORT=8080

# Secreto para firmar tokens JWT
JWT_SECRET=super_secret_jwt_key_change_me_in_production

# Token de Acceso de Mercado Pago (Producción o Sandbox)
MERCADO_PAGO_ACCESS_TOKEN=APP_USR-xxxxxx-xxxxxx-xxxxxx

# URL de Webhook pública de Mercado Pago (usada para recibir notificaciones de pago)
# Debe ser la URL de tu servidor, por ejemplo: https://tu-dominio.com/api/webhooks/mercadopago
MERCADO_PAGO_WEBHOOK_URL=http://localhost:8080/api/webhooks/mercadopago

# Credenciales de administrador por defecto (se crearán al iniciar la base de datos si no existen)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=adminpass
